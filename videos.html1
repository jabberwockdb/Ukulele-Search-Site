<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, minimal-ui">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <title>Ukulele Friends - Open Mic Videos</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
    <script src="https://www.youtube.com/iframe_api"></script>
    <script>
        if (localStorage.getItem("uke_authenticated") !== "true") {
            window.location.href = "index.html";
        }

        // Mobile Address Bar Minimization Kick Routine
        window.addEventListener("load", function() {
            setTimeout(function() {
                window.scrollTo(0, 1);
            }, 100);
        });
    </script>
    <style>
        /* Synced global canvas layout constraints across index types */
        html, body {
            margin: 0;
            padding: 0;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.15)), url('login_search_background.png') no-repeat center -40px fixed;
            background-size: cover;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* Responsive Landscape Advisory Banner for Mobile Devices */
        .orientation-alert-banner {
            display: none;
            width: 100%;
            background-color: #ffcc00;
            color: #000;
            text-align: center;
            padding: 8px 10px;
            font-size: 13px;
            font-weight: bold;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
            z-index: 1000;
            box-sizing: border-box;
        }

        @media screen and (max-device-width: 768px) and (orientation: portrait) {
            .orientation-alert-banner {
                display: block;
            }
        }

        /* 1. PERMANENTLY STATIONARY TOP ZONE */
        .stationary-top-zone {
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            flex-shrink: 0;
            background: transparent;
            z-index: 100;
        }

        /* Harmonized Menu Strip Position Settings */
        .top-navigation-bar {
            width: 100%;
            height: 45px;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 20px;
            padding-top: 5px;
            background: rgba(0, 0, 0, 0.15);
        }

        .menu-item-text {
            text-decoration: none;
            font-size: 17px;
            font-weight: bold;
            padding: 6px 22px;
            border-radius: 6px;
            color: #ffd699; 
            background: rgba(90, 45, 20, 0.85); 
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.2s ease-in-out;
            white-space: nowrap;
        }

        .menu-item-text:hover {
            background: rgba(140, 60, 20, 0.95);
            color: #ffffff;
        }

        .menu-item-text.active {
            color: #ffffff; 
            background: rgba(230, 92, 0, 0.95); 
            border: 1px solid rgba(255, 255, 255, 0.3);
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
        }

        /* Harmonized Upper Structural Header Control Component */
        .header-control-zone {
            width: 96%;
            max-width: 1200px;
            height: 160px; 
            margin-top: 15px;
            margin-bottom: 5px;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Performers Sidebar Container - Tailored exactly to match the source table template layout */
        .left-performers-sidebar {
            position: absolute;
            left: 0;
            top: 10px; 
            height: 135px; 
            display: flex;
            flex-direction: column;
            background: rgba(40, 20, 5, 0.82); 
            padding: 10px 14px;
            border-radius: 8px;
            width: 260px;
            box-sizing: border-box;
            border: 1px solid rgba(255, 214, 153, 0.3);
            z-index: 200; 
        }

        .sidebar-header-wrapper {
            margin-bottom: 8px;
            flex-shrink: 0; 
            border-bottom: 1px solid rgba(255, 214, 153, 0.4);
            padding-bottom: 4px;
        }

        .sidebar-label {
            font-size: 13px;
            font-weight: bold;
            color: #ffd699;
            text-transform: uppercase;
            letter-spacing: 1px;
            text-shadow: 1px 1px 4px rgba(0,0,0,0.9);
            text-align: left;
            display: inline-block;
        }

        /* Performers Inner Scrolling List Container Track */
        .performers-scroll-tray {
            flex-grow: 1; 
            overflow-y: auto;
            display: block; 
            padding-right: 4px;
        }

        .performers-scroll-tray::-webkit-scrollbar {
            width: 6px;
        }
        .performers-scroll-tray::-webkit-scrollbar-thumb {
            background: rgba(230, 92, 0, 0.9);
            border-radius: 3px;
        }

        /* Custom Interactive Text Elements representing performers list options */
        .performer-anchor-row {
            color: #ffffff !important; 
            text-decoration: none !important;
            font-size: 13px;
            font-weight: 600;
            line-height: 18px; 
            margin-bottom: 6px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            display: block; 
            text-align: left;
            text-shadow: 1px 1px 2px rgba(0,0,0,1);
            transition: all 0.12s ease-in-out;
            width: 100%;
            cursor: pointer;
        }

        .performer-anchor-row:hover {
            color: #ffd699 !important;
            transform: translateX(3px);
        }

        /* Highlights active performer selection */
        .performer-anchor-row.selected-performer {
            color: #ffaa66 !important;
            font-weight: 700;
            text-decoration: underline !important;
        }

        /* Central Wooden Branding Sign Graphic Frame */
        .center-sign-asset {
            display: flex;
            align-items: center;
            justify-content: center;
            pointer-events: none;
            height: 135px;
            width: 380px;
            z-index: 50; 
        }

        /* 2. MAIN LOWER THEATER WORKSPACE VIEWPORT LAYER */
        .main-theater-viewport {
            width: 96%;
            max-width: 1200px;
            flex: 1;
            display: flex;
            box-sizing: border-box;
            background: rgba(0, 0, 0, 0.55);
            border: 1px solid rgba(255, 214, 153, 0.2);
            border-radius: 8px;
            margin-top: 5px;
            margin-bottom: 25px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }

        .video-screen-pane {
            flex: 1;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #000;
            position: relative;
            padding: 15px;
            box-sizing: border-box;
        }

        .video-container-constrained {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .playlist-sidebar-pane {
            width: 340px;
            height: 100%;
            background: rgba(20, 20, 20, 0.94);
            border-left: 2px solid rgba(230, 92, 0, 0.6);
            display: flex;
            flex-direction: column;
            box-sizing: border-box;
        }

        .sidebar-header {
            background: #e65c00;
            color: #fff;
            padding: 12px 15px;
            font-size: 14px;
            font-weight: bold;
            box-shadow: 0 2px 5px rgba(0,0,0,0.3);
            text-align: left;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .sidebar-scroll-list {
            flex: 1;
            overflow-y: auto;
            padding: 10px;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .playlist-track-row {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 4px;
            padding: 8px;
            color: #ccc;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.15s ease-in-out;
            text-align: left;
            line-height: 1.4;
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .playlist-track-row:hover {
            background: rgba(230, 92, 0, 0.15);
            border-color: #e65c00;
            color: #fff;
        }

        .playlist-track-row.active-track {
            background: #e65c00;
            border-color: #ff751a;
            color: #fff;
            font-weight: bold;
        }

        .track-thumb {
            width: 65px;
            height: 45px;
            object-fit: cover;
            border-radius: 2px;
            background: #222;
        }

        .track-details {
            flex: 1;
            white-space: normal;
            word-break: break-word;
        }
    </style>
</head>
<body>

<div class="orientation-alert-banner">🔄 For the best viewing experience, please rotate your device to Landscape view.</div>

<div class="stationary-top-zone">
    <div class="top-navigation-bar">
        <a href="search.html" class="menu-item-text">Song Search</a>
        <a href="videos.html" class="menu-item-text active">Open Mic Videos</a>
    </div>

    <div class="header-control-zone">
        <div class="left-performers-sidebar">
            <div class="sidebar-header-wrapper">
                <span class="sidebar-label">Performers</span>
            </div>
            <div id="performersScrollTray" class="performers-scroll-tray">
                <span style="color:#eee; font-size:11px; font-style:italic;">Loading records...</span>
            </div>
        </div>
        
        <div class="center-sign-asset">
            <div style="width:380px; height:115px; background:url('ukulele_friends_sign.png') no-repeat center; background-size:contain;"></div>
        </div>
    </div>
</div>

<div class="main-theater-viewport">
    <div class="video-screen-pane">
        <div class="video-container-constrained">
            <div id="playerElement" style="width:100%; height:100%;"></div>
        </div>
    </div>

    <div class="playlist-sidebar-pane">
        <div id="sidebarTitle" class="sidebar-header">Playlist Performances</div>
        <div id="trackListContainer" class="sidebar-scroll-list">
            <p style="color:#aaa; font-style:italic; padding:10px;">Connecting to system records...</p>
        </div>
    </div>
</div>

<script>
    let player = null;
    let playlistData = [];
    let apiReady = false;
    let csvReady = false;
    let currentActiveIdx = 0;

    const sidebarTitle = document.getElementById("sidebarTitle");
    const trackContainer = document.getElementById("trackListContainer");
    const performersScrollTray = document.getElementById("performersScrollTray");

    function extractPlaylistID(url) {
        if (!url) return "";
        let match = url.match(/[&?]list=([^&]+)/);
        if (match && match[1]) return match[1].trim();
        return url.trim();
    }

    function onYouTubeIframeAPIReady() {
        apiReady = true;
        initEngineBootstrap();
    }

    function initEngineBootstrap() {
        if (apiReady && csvReady && playlistData.length > 0) {
            selectPerformer(0);
        }
    }

    function selectPerformer(index) {
        currentActiveIdx = index;
        const targetRow = playlistData[index];
        
        document.querySelectorAll('.performer-anchor-row').forEach((el, idx) => {
            if (idx === index) el.classList.add('selected-performer');
            else el.classList.remove('selected-performer');
        });

        loadPerformerPlaylist(targetRow.link, targetRow.performer);
    }

    function loadPerformerPlaylist(rawUrl, name) {
        const playlistID = extractPlaylistID(rawUrl);
        sidebarTitle.innerText = name + "'s Collection";
        trackContainer.innerHTML = "<p style='color:#aaa; font-style:italic; padding:10px;'>Fetching live data fields...</p>";

        if (player) {
            player.destroy();
        }

        player = new YT.Player('playerElement', {
            height: '100%',
            width: '100%',
            playerVars: {
                listType: 'playlist',
                list: playlistID,
                rel: 0,
                modestbranding: 1,
                iv_load_policy: 3
            },
            events: {
                'onReady': onPlayerReady,
                'onStateChange': onPlayerStateChange
            }
        });
    }

    function onPlayerReady(event) {
        const rawPlaylistArray = event.target.getPlaylist();
        if (rawPlaylistArray && rawPlaylistArray.length > 0) {
            buildLivePlaylistSidebar(rawPlaylistArray);
        } else {
            trackContainer.innerHTML = "<p style='color:#888; padding:10px; font-style:italic;'>Playlist details could not be parsed.</p>";
        }
    }

    function onPlayerStateChange(event) {
        if (event.data === YT.PlayerState.PLAYING || event.data === YT.PlayerState.BUFFERING) {
            const index = event.target.getPlaylistIndex();
            document.querySelectorAll('.playlist-track-row').forEach((row, idx) => {
                if (idx === index) row.classList.add('active-track');
                else row.classList.remove('active-track');
            });
        }
    }

    function buildLivePlaylistSidebar(idArray) {
        trackContainer.innerHTML = "";
        
        idArray.forEach((videoID, index) => {
            const thumbUrl = `https://img.youtube.com/vi/${videoID}/default.jpg`;
            
            const row = document.createElement("div");
            row.id = "track-row-idx-" + index;
            row.className = "playlist-track-row";
            if (index === 0) row.classList.add("active-track");

            row.innerHTML = `
                <img class="track-thumb" src="${thumbUrl}" alt="clip">
                <div class="track-details" id="details-text-${index}">Performance Title #${index + 1}</div>
            `;

            row.onclick = function() {
                if (player && typeof player.playVideoAt === 'function') {
                    player.playVideoAt(index);
                }
            };

            trackContainer.appendChild(row);

            fetch(`https://noembed.com/embed?url=https://www.youtube.com/watch?v=${videoID}`)
                .then(res => res.json())
                .then(data => {
                    if (data && data.title) {
                        document.getElementById(`details-text-${index}`).innerText = data.title;
                    }
                })
                .catch(err => { console.log("Fallback title applied."); });
        });
    }

    Papa.parse("playlists.csv?v=29", {
        download: true,
        header: true,
        skipEmptyLines: true,
        complete: function(results) {
            const rawRows = results.data;
            performersScrollTray.innerHTML = "";

            function findValue(rowObj, searchKey) {
                const target = searchKey.toLowerCase().replace(/[^a-z0-9]/g, "");
                for (let k in rowObj) {
                    if (k.toLowerCase().replace(/[^a-z0-9]/g, "") === target) {
                        return rowObj[k] ? rowObj[k].toString().trim() : "";
                    }
                }
                return "";
            }

            playlistData = rawRows.map(row => {
                return {
                    performer: findValue(row, "performer") || findValue(row, "name"),
                    link: findValue(row, "link") || findValue(row, "playlist")
                };
            }).filter(item => item.performer && item.link);

            if (playlistData.length === 0) {
                performersScrollTray.innerHTML = "<span style='color:#eee; font-size:12px;'>No records found.</span>";
                return;
            }

            playlistData.forEach((item, index) => {
                const rowItem = document.createElement("div");
                rowItem.className = "performer-anchor-row";
                rowItem.textContent = item.performer;
                rowItem.onclick = function() { selectPerformer(index); };
                performersScrollTray.appendChild(rowItem);
            });

            csvReady = true;
            initEngineBootstrap();
        }
    });
</script>

</body>
</html>
